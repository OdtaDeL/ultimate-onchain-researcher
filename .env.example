# Copy this file to .env and fill in real values. Never commit .env —
# it's already covered by .gitignore.
#
# All variables below are validated by the single source of truth at
# src/config/env.ts — see that file for which entry point needs which
# variable and why. No other file in this codebase reads process.env
# directly.

# ---------------------------------------------------------------------
# Supabase — required by the Next.js web app (API routes)
# ---------------------------------------------------------------------

# Your Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase anon/public key. Used by the web app's read-only API routes
# (src/app/api/**) — requests go through Postgres RLS like any other
# anonymous client. Safe to expose to a server process; never bundled
# into client-side JS by this codebase. Find it in
# Supabase Dashboard -> Project Settings -> API -> anon/public key.
SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------
# Supabase — required only by the ingestion CLI scripts (src/cli/*.ts,
# run via `npm run sync:*`). NOT required to run the web app
# (`npm run dev` / `build` / `start`) and never imported by anything
# reachable from an HTTP request.
# ---------------------------------------------------------------------

# Supabase service-role key. Bypasses Row Level Security entirely — used
# for ingestion writes only. Treat as a secret with full database access;
# never expose this to a browser or commit it anywhere.
# Find it in Supabase Dashboard -> Project Settings -> API -> service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------
# Telegram — optional for local development, required for production
# ---------------------------------------------------------------------

# Telegram Bot Token. When set, proxy.ts verifies every /api/* request's
# Telegram initData HMAC-SHA256 signature in production, ensuring only real
# Telegram Mini App sessions can reach the API. Obtain from @BotFather.
# Leave empty in development — initData verification is automatically skipped
# when NODE_ENV != "production" or this variable is unset.
TELEGRAM_BOT_TOKEN=
